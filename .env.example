# Per-channel Instagram credentials (one set per channel, prefixed by secret_prefix)
DRIFTED_LINES_IG_ACCESS_TOKEN=
DRIFTED_LINES_IG_USER_ID=
DRIFTED_LINES_IG_APP_ID=
DRIFTED_LINES_IG_APP_SECRET=

# GitHub token - only needed locally for testing the GitHub Contents API path.
# In GitHub Actions, the workflow injects TOKEN from the repo secret if present,
# otherwise it falls back to the built-in github.token.
TOKEN=
# Backward-compatible local fallback:
GITHUB_TOKEN=

# Only needed if running token_refresh locally (normally runs in Actions).
SECRETS_WRITE_PAT=
